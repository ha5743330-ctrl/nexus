# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database
MONGO_URI=mongodb://localhost:27017/nexus

# Auth
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_this_too_to_a_long_random_string
JWT_REFRESH_EXPIRES_IN=30d

# Email (Nodemailer - use Mailtrap/Ethereal in dev, real SMTP in prod)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Nexus <no-reply@nexus.dev>

# Payments (Stripe sandbox)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

# File storage
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=15

# If using AWS S3 instead of local disk storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=
